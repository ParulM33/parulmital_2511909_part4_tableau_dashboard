      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' default-format='p0.0%' name='[Calculation_1382378892718080]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit])/ SUM([sales])' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_1382378900549634]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[sales]-[profit]' />
      </column>
      <column caption='Average Order value' datatype='real' name='[Calculation_1382378900750339]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales])/COUNTD([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_1382378904629253]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([delivery_days]) THEN &quot;Unknown&quot;&#13;&#10;ELSEIF [delivery_days] &lt; 0 THEN &quot;Invalid&quot;&#13;&#10;ELSEIF [delivery_days] &lt;= 2 THEN &quot;On-Time&quot;&#13;&#10;ELSEIF [delivery_days] &lt;= 5 THEN &quot;Slight Delay&quot;&#13;&#10;ELSE &quot;Major Delay&quot;&#13;&#10;END' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_1382378908827654]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag]) / COUNT([order_id])' />
      </column>
      <column caption='dashboard_sales_data' datatype='table' name='[__tableau_internal_object_id__].[dashboard!sales!data_3D31E64C869B4AAB86D997CFE9BEFC64]' role='measure' type='quantitative' />
